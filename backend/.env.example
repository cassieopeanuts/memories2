PORT=5000
NODE_ENV=development

# Database Settings (Set MOCK_DATABASE to true to use local JSON file database instead of Postgres)
MOCK_DATABASE=true
DB_USER=cass
DB_PASSWORD=supersecurepassword123
DB_HOST=localhost
DB_NAME=memories
DB_PORT=5432

# Security Settings
JWT_SECRET=ag_very_secret_token_12345!

# Storage Settings (Set MOCK_S3 to true for offline testing without Selectel S3)
MOCK_S3=true
S3_ENDPOINT=https://s3.ru-1.storage.selcloud.ru
S3_REGION=ru-1
S3_ACCESS_KEY_ID=your_selectel_access_key
S3_SECRET_ACCESS_KEY=your_selectel_secret_key
S3_BUCKET_NAME=memories-photos

# SSO Settings (The primary address of the React frontend app)
FRONTEND_URL=http://localhost:5180
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
REDIRECT_URI=http://localhost:5000/api/auth/yandex/callback

SBER_CLIENT_ID=your_sber_client_id
SBER_CLIENT_SECRET=your_sber_client_secret
SBER_REDIRECT_URI=http://localhost:5000/api/auth/sber/callback

# SMTP Mail Server Settings (Selectel Mail Service or custom SMTP)
# For Selectel SMTP in production, use host: smtp.mail.selcloud.ru, port: 1127, secure: true
# For local dev with Mailpit, use host: mailpit, port: 1025, secure: false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=no-reply@xn--80affoidsgaujr8a0h.xn--p1ai
SMTP_PASS=
FEEDBACK_RECEIVER=admin@xn--80affoidsgaujr8a0h.xn--p1ai
